{
	"name": "scrollviewer2",
	"version": "2.1.6",
	"description": "ScrollViewer2 - long-strip comic/image viewer",
	"main": "src/main/main.js",
	"scripts": {
		"start": "electron .",
		"test": "node --test",
		"dist": "electron-builder --publish=never"
	},
	"author": "Purpal@ptt.cc",
	"license": "ISC",
	"dependencies": {
		"node-unrar-js": "^2.0.2",
		"utif2": "^4.1.0",
		"yauzl": "^3.4.0"
	},
	"devDependencies": {
		"electron": "^43.0.0",
		"electron-builder": "^26.15.3"
	},
	"build": {
		"appId": "com.purpal.scrollviewer2",
		"productName": "ScrollViewer2",
		"files": [
			"src/**/*",
			"img/**/*",
			"package.json"
		],
		"directories": {
			"output": "dist"
		},
		"win": {
			"target": "nsis",
			"icon": "img/icon.png"
		},
		"mac": {
			"target": "dmg",
			"icon": "img/icon.png"
		},
		"linux": {
			"target": "AppImage",
			"icon": "img/icon.png"
		}
	}
}
